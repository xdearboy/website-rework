{
    "organizeImports": {
        "enabled": true
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "suspicious": {
                "noExplicitAny": "off"
            },
            "style": {
                "noNonNullAssertion": "off"
            },
            "a11y": {
                "useKeyWithClickEvents": "warn"
            }
        }
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 2,
        "lineWidth": 100
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "trailingCommas": "es5",
            "semicolons": "always"
        }
    },
    "files": {
        "include": [
            "src/**",
            "plugins/**"
        ],
        "ignore": [
            "src/__tests__",
            "plugins/__tests__",
            "src/components/ui/use-toast.ts",
            "src/components/ui/use-mobile.tsx"
        ]
    }
}