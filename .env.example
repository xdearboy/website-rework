# Public base URL the frontend uses to load the gallery manifest and images.
# Yandex Object Storage example: https://storage.yandexcloud.net/<bucket> (no trailing slash).
VITE_GALLERY_BASE_URL=

# Used only by scripts/upload-gallery.ts (S3-compatible: Yandex Object Storage, MinIO, R2).
# Yandex: https://storage.yandexcloud.net | MinIO: your MinIO URL | R2: https://<account>.r2.cloudflarestorage.com
S3_ENDPOINT=
# Region (Yandex: ru-central1).
S3_REGION=ru-central1
# Static access key for a service account with object storage write access.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Bucket name used for gallery storage.
S3_BUCKET=
# Public base URL for objects (same value as VITE_GALLERY_BASE_URL).
GALLERY_BASE_URL=
# Local folder scanned by the upload script (category subfolders with photos inside).
GALLERY_SRC=./gallery-src
